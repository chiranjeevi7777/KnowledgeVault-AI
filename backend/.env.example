# ── Box API (Developer Token) ──────────────────────────────────────────────────
# Generate at: https://app.box.com/developers/console → your app → Configuration
# → "Developer Token" section → click "Generate Developer Token"
# Note: Developer tokens expire after 60 minutes. Regenerate when needed.
BOX_DEVELOPER_TOKEN=your_developer_token_here
BOX_CLIENT_ID=your_client_id_here
BOX_CLIENT_SECRET=your_client_secret_here

# Root folder to scan. Use "0" for your Box root, or paste a specific folder ID.
# Find folder ID in the Box URL: https://app.box.com/folder/XXXXXXXXX
BOX_ROOT_FOLDER_ID=0

# ── Amazon Bedrock LLM ────────────────────────────────────────────────────────
# AWS credentials — use IAM user keys or run `aws configure` to set up the CLI
# Alternatively, leave these blank and use AWS_PROFILE for named CLI profiles
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SESSION_TOKEN=          # Leave blank unless using temporary STS/role credentials
AWS_REGION=us-east-1

# Bedrock model — must be enabled in your account: AWS Console > Bedrock > Model access
# Options:
#   anthropic.claude-3-5-sonnet-20241022-v2:0   (latest / most capable)
#   anthropic.claude-3-sonnet-20240229-v1:0     (balanced speed & quality)
#   anthropic.claude-3-haiku-20240307-v1:0      (fastest / cheapest)
#   amazon.titan-text-express-v1                (Amazon native model)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ── Embeddings (runs locally, no API key needed) ───────────────────────────────
# Downloads ~90MB on first run, then cached locally
# Options: all-MiniLM-L6-v2 (fast/small) | all-mpnet-base-v2 (slower/better)
EMBED_MODEL=all-MiniLM-L6-v2

# ── Whisper Transcription (runs locally) ───────────────────────────────────────
# Model is downloaded on first use. Options: tiny | base | small | medium | large
WHISPER_MODEL=base

# ── ChromaDB (local persistent vector database) ────────────────────────────────
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=box_agent_transcripts

# ── Text Chunking ──────────────────────────────────────────────────────────────
CHUNK_SIZE=2000
CHUNK_OVERLAP=200
